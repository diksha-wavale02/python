#prime

n=int(input("enter a number:"))
if n>1:
    flag=0
for i in range(2,n):
    if n%i==0:
        flag=1
        break
if flag==0:
    print("prime")
else:
    print("not prime")    
    
#palindrome 


n=int(input("enter a number:"))
temp=n
rev=0
while n>0:
    rem=n%10
    rev=rev*10+rem
    n=n//10
if temp==rev:
    print("palindrome")
else:
    print("not palindrome")        

